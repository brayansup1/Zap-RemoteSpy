-- Guardar en tu carpeta 'autoexec'. Servidores reservados exclusivos.

local TeleportService = game:GetService("TeleportService")
local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")

if not game:IsLoaded() then
	game.Loaded:Wait()
end

local LocalPlayer = Players.LocalPlayer
while not LocalPlayer do
	task.wait(0.1)
	LocalPlayer = Players.LocalPlayer
end

local fList = {"Budha", "Chop", "Flame", "Gear2", "Ice", "Light", "Magma", "Mochi", "Quake", "Rubber", "Sand", "String"}

-- FUNCIÓN PARA CREAR Y SALTAR A UN SERVIDOR RESERVADO FRESCO
local function iniciarServerHopExclusivo()
	print("🌀 Generando un servidor reservado completamente nuevo...")
	
	local success, result = pcall(function()
		-- Reservamos un código de acceso único para una sala limpia
		local codigoReserva, _ = TeleportService:ReserveServer(game.PlaceId)
		-- Nos teletransportamos de forma directa usando ese código
		TeleportService:TeleportToPrivateServer(game.PlaceId, codigoReserva, {LocalPlayer})
	end)
	
	if not success then
		warn("❌ Falló la reserva nativa, usando emparejamiento estándar de respaldo: " .. tostring(result))
		task.wait(2)
		TeleportService:Teleport(game.PlaceId, LocalPlayer)
	end
end

print(`🕒 [{os.date("%X")}] [Radar Reservado] Analizando entorno...`)
task.wait(1.5)

local frutaObjetivo = nil

-- 1. BUSQUEDA DIRECTA
for _, o in ipairs(Workspace:GetDescendants()) do
	if table.find(fList, o.Name) and (o:IsA("Model") or o:IsA("BasePart")) then
		frutaObjetivo = o
		break
	end
end

-- 2. EVALUACIÓN DE ACCIONES CONTINUAS
if frutaObjetivo then
	local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
	local rootPart = character:WaitForChild("HumanoidRootPart", 5)
	
	if rootPart then
		print(`🎉 ¡FRUTA DETECTADA! -> {frutaObjetivo.Name} a las {os.date("%X")}`)
		rootPart.CFrame = frutaObjetivo:GetPivot() * CFrame.new(0, 3, 0)
		
		print("⏳ Monitoreando recolección para preparar el próximo servidor exclusivo...")
		
		-- Espera a que recojas la fruta (desaparezca del Workspace)
		while frutaObjetivo and frutaObjetivo:IsDescendantOf(Workspace) do
			task.wait(1)
		end
		
		print("🧹 Fruta recolectada. Limpiando sesión...")
		task.wait(1)
		iniciarServerHopExclusivo()
	end
else
	print("❌ Este servidor no contiene spawns activos. Saltando de inmediato...")
	iniciarServerHopExclusivo()
end
