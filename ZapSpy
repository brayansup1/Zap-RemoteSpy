-- 5. FUNCIÓN CENTRALIZADA DE ESCANEO REUTILIZABLE
local function ejecutarEscaneo(silencioso: boolean)
	if not silencioso then
		BotonEscaneo.Text = "ESCANEANDO..."
		BotonEscaneo.BackgroundColor3 = Color3.fromRGB(230, 126, 34)
	end
	
	local listaFiltroActiva = {}
	for _, item in ipairs(FrutasConfig) do
		if item[2] == true then
			table.insert(listaFiltroActiva, item[1])
		end
	end
	
	local encontrada = false
	
	for _, objeto in ipairs(Workspace:GetDescendants()) do
		if table.find(listaFiltroActiva, objeto.Name) and (objeto:IsA("Model") or objeto:IsA("BasePart")) then
			local character = LocalPlayer.Character
			local rootPart = character and character:FindFirstChild("HumanoidRootPart")
			
			if rootPart then
				print(`🎯 [Radar] ¡Localizada automáticamente!: {objeto.Name}`)
				rootPart.CFrame = objeto:GetPivot() * CFrame.new(0, 3, 0)
				encontrada = true
				break
			end
		end
	end
	
	if not silencioso then
		if encontrada then
			BotonEscaneo.Text = "✅ ¡ENCONTRADA!"
			BotonEscaneo.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
		else
			BotonEscaneo.Text = "❌ SIN FRUTAS"
			BotonEscaneo.BackgroundColor3 = Color3.fromRGB(231, 76, 60)
		end
		task.wait(1.2)
		BotonEscaneo.Text = "🔍 ESCANEAR AHORA"
		BotonEscaneo.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
	end
end

-- Conexión al botón manual
BotonEscaneo.MouseButton1Click:Connect(function()
	ejecutarEscaneo(false)
end)

-- 6. LOOP DE AUTOMATIZACIÓN OPTIMIZADO (Segundo plano constante)
task.spawn(function()
	print("⚙️ [Automatizador] Loop de escaneo de fondo iniciado (Cada 15s)...")
	while true do
		task.wait(15) -- Revisa cada 15 segundos sin causar tirones ni lag en el procesador móvil
		ejecutarEscaneo(true) -- Escaneo silencioso en segundo plano
	end
end)
