-- Guardar en tu carpeta 'autoexec'. Sistema de ruptura de bucle regional.

local TeleportService = game:GetService("TeleportService")
local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")

if not game:IsLoaded() then
	game.Loaded:Wait()
end

local LocalPlayer = Players.LocalPlayer
while not LocalPlayer do
	task.wait(0.1)
	LocalPlayer = Players.LocalPlayer
end

-- 1. DETECTOR DE REGRESO (ANTI-REPETICIÓN)
-- Usamos los atributos del juego para recordar en qué servidor estuviste antes de saltar
local ultimoServer = LocalPlayer:GetAttribute("LastServerId")
if ultimoServer == game.JobId then
	print("⚠️ [Alerta] Roblox te intentó meter al mismo servidor. Forzando reconexión limpia...")
	task.wait(1)
	-- Al usar un teletransporte genérico tras un bloqueo, forzamos la ruptura de caché de red
	TeleportService:Teleport(game.PlaceId, LocalPlayer)
	return
else
	LocalPlayer:SetAttribute("LastServerId", game.JobId)
end

local fList = {"Budha", "Chop", "Flame", "Gear2", "Ice", "Light", "Magma", "Mochi", "Quake", "Rubber", "Sand", "String"}

print(`🕒 [{os.date("%X")}] [Radar Anti-Bucle] Conectado a: {game.JobId}`)
task.wait(1.5)

local frutaObjetivo = nil

-- 2. ESCANEO DEL MAPA
for _, o in ipairs(Workspace:GetDescendants()) do
	if table.find(fList, o.Name) and (o:IsA("Model") or o:IsA("BasePart")) then
		frutaObjetivo = o
		break
	end
end

-- 3. FLUJO DE ACCIONES
if frutaObjetivo then
	local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
	local rootPart = character:WaitForChild("HumanoidRootPart", 5)
	
	if rootPart then
		print(`🎉 ¡FRUTA LOCALIZADA! -> {frutaObjetivo.Name} a las {os.date("%X")}`)
		rootPart.CFrame = frutaObjetivo:GetPivot() * CFrame.new(0, 3, 0)
		
		-- Esperar a que la recojas
		while frutaObjetivo and frutaObjetivo:IsDescendantOf(Workspace) do
			task.wait(1)
		end
		
		print("🧹 Fruta recogida. Saltando de servidor...")
		task.wait(1)
		TeleportService:Teleport(game.PlaceId, LocalPlayer)
	end
else
	print("❌ Servidor limpio. Cambiando de sala...")
	task.wait(0.5)
	TeleportService:Teleport(game.PlaceId, LocalPlayer)
end
