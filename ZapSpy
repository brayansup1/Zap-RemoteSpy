--!strict
task.spawn(function()
	print("✨ [Radar Activo] Iniciando escaneo inmediato de frutas y Auto-Hop...")

	local Workspace = game:GetService("Workspace")
	local Players = game:GetService("Players")
	local TeleportService = game:GetService("TeleportService")
	local HttpService = game:GetService("HttpService")
	
	local LocalPlayer = Players.LocalPlayer or Players:GetPlayers()[1]
	local placeId = game.PlaceId
	local currentJobId = game.JobId

	local NombresFrutas = {"Budha", "Chop", "Flame", "Gear2", "Ice", "Light", "Magma", "Mochi", "Quake", "Rubber", "Sand", "String"}

	-- 1. FUNCIÓN DE INGENIERÍA INVERSA PARA CAMBIAR DE SERVIDOR (SERVER HOP)
	local function forzarServerHop()
		print("🌐 Buscando un nuevo servidor público con espacios disponibles...")
		local url = string.format("https://games.roproxy.com/v1/games/%s/servers/Public?sortOrder=Asc&limit=100", tostring(placeId))
		
		local success, result = pcall(function()
			return game:HttpGet(url)
		end)

		if not success then
			warn("❌ Error al obtener la lista de servidores alternativos: " .. tostring(result))
			return
		end

		local data = HttpService:JSONDecode(result)
		local servidoresValidos = {}

		if data and data.data then
			for _, server in ipairs(data.data) do
				if server.playing < server.maxPlayers and server.id ~= currentJobId then
					table.insert(servidoresValidos, server.id)
				end
			end
		end

		if #servidoresValidos > 0 then
			local nuevoServidor = servidoresValidos[math.random(1, #servidoresValidos)]
			print(`🚀 Servidor encontrado. Teletransportando al JobId: {nuevoServidor}`)
			TeleportService:TeleportToPlaceInstance(placeId, nuevoServidor, LocalPlayer)
		else
			warn("⏳ No se encontraron servidores con espacio libre en este instante. Reintentando salto...")
			task.wait(5)
			forzarServerHop()
		end
	end

	-- 2. FUNCIÓN DE BÚSQUEDA Y REGISTRO DE TIEMPO
	local function buscarFrutaExistente(): boolean
		-- Imprime la hora exacta (Hora:Minutos:Segundos) de la verificación en tu consola
		print(`🕒 [{os.date("%X")}] Analizando el Workspace del servidor actual...`)
		
		for _, objeto in Workspace:GetDescendants() do
			if table.find(NombresFrutas, objeto.Name) and (objeto:IsA("Model") or objeto:IsA("BasePart")) then
				local character = LocalPlayer.Character
				local rootPart = character and character:FindFirstChild("HumanoidRootPart")
				
				if rootPart then
					print(`🎉 ¡FRUTA DETECTADA! -> {objeto.Name} encontrada exactamente a las {os.date("%X")}`)
					print(`📍 Coordenadas: {tostring(objeto:GetPivot().Position)}`)
					
					-- Teletransporte inmediato hacia el spawn local generado
					rootPart.CFrame = objeto:GetPivot() * CFrame.new(0, 3, 0)
					return true -- Detiene el flujo de salto porque encontramos el objetivo
				end
			end
		end
		return false -- No hay frutas en este servidor
	end

	-- 3. ESCUCHA EN TIEMPO REAL (Por si aparece en el segundo en que entras)
	local frutaDetectadaPorSeñal = false
	local conexionDescendant = Workspace.DescendantAdded:Connect(function(descendant)
		if table.find(NombresFrutas, descendant.Name) then
			frutaDetectadaPorSeñal = true
			task.wait(0.2)
			print(`✨ ¡Detección Instantánea vía Red/Zap! Fruta: {descendant.Name} | Hora: {os.date("%X")}`)
			buscarFrutaExistente()
		end
	end)

	-- 4. EJECUCIÓN DEL FLUJO ÓPTIMO (Fase de carga inicial)
	task.wait(2) -- Breve pausa técnica para asegurar que las carpetas locales carguen
	
	local frutaEncontrada = buscarFrutaExistente()
	
	if frutaEncontrada or frutaDetectadaPorSeñal then
		print("✅ Proceso pausado. Te encuentras junto a la fruta. Examina los registros de tiempo arriba.")
	else
		print("❌ No se detectó ninguna fruta activa en este mapa. Iniciando cambio de servidor de inmediato...")
		conexionDescendant:Disconnect() -- Limpiar la conexión antes de salir
		task.wait(1)
		forzarServerHop()
	end
end)
