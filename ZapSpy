-- Mover personaje suavemente
local function moverAPosicion(posicion, velocidad)
	local character = LocalPlayer.Character
	local rootPart = character and character:FindFirstChild("HumanoidRootPart")
	if not rootPart then return false end
	
	local distancia = (posicion - rootPart.Position).Magnitude
	local tiempo = distancia / (velocidad or 50)
	
	local tween = TweenService:Create(rootPart, TweenInfo.new(tiempo, Enum.EasingStyle.Linear), {
		CFrame = CFrame.new(posicion)
	})
	tween:Play()
	tween.Completed:Wait()
	return true
end

-- Encontrar NPC por nombre
local function encontrarNPC(nombre)
	for _, obj in ipairs(Workspace:GetDescendants()) do
		if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj:FindFirstChild("HumanoidRootPart") then
			if obj.Name == nombre or obj.Name:find(nombre) then
				return obj
			end
		end
	end
	return nil
end

-- Encontrar ProximityPrompt
local function encontrarPrompt(npc)
	if not npc then return nil end
	for _, obj in ipairs(npc:GetDescendants()) do
		if obj:IsA("ProximityPrompt") then
			return obj
		end
	end
	return nil
end

