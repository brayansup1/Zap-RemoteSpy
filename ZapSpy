task.spawn(function()
    print("🚀 Monitor de Frutas y Teletransporte Activado (Cada 10 min o detección inmediata)...")
    
    local Players = game:GetService("Players")
    local LocalPlayer = Players.LocalPlayer
    local Workspace = game:GetService("Workspace")
    
    -- Configuración de rutas según lo que encontraste
    local SpawnsFolder = Workspace:WaitForChild("Spawns", 5):WaitForChild("Fruits", 5)
    local NombresFrutas = {"Budha", "Chop", "Flame", "Gear2", "Ice", "Light", "Magma", "Mochi", "Quake", "Rubber", "Sand", "String"}
    
    -- Función interna para buscar si la fruta ya se renderizó en el Workspace
    local function verificarYTeletransportar()
        print(`🕒 [{os.date("%X")}] Ejecutando verificación de rutina...`)
        
        -- Buscamos en todo el Workspace si apareció algún modelo con el nombre de las frutas
        for _, objeto in Workspace:GetDescendants() do
            if table.find(NombresFrutas, objeto.Name) and (objeto:IsA("Model") or objeto:IsA("BasePart")) then
                local character = LocalPlayer.Character
                local rootPart = character and character:FindFirstChild("HumanoidRootPart")
                
                if rootPart then
                    print(`🍎 ¡Fruta encontrada! {objeto.Name}. Teletransportando...`)
                    -- Te mueve 3 posiciones arriba de la fruta para no quedar atrapado en el suelo
                    rootPart.CFrame = objeto:GetPivot() * CFrame.new(0, 3, 0) 
                    return true
                end
            end
        end
        return false
    end

    -- 1. Escucha en tiempo real: Si Zap la clona en el Workspace, el comando la detecta al instante
    Workspace.DescendantAdded:Connect(function(descendant)
        if table.find(NombresFrutas, descendant.Name) then
            task.wait(0.2) -- Esperar un instante a que se posicione bien el modelo
            print(`✨ ¡Zap acaba de spawnear una fruta localmente: {descendant.Name}!`)
            verificarYTeletransportar()
        end
    end)

    -- 2. Bucle de respaldo: Revisa minuciosamente cada 10 minutos por si acaso
    while true do
        local encontrada = verificarYTeletransportar()
        if encontrada then
            print("✅ Teletransporte completado. El monitor seguirá activo.")
        else
            print("⏳ No se encontraron frutas clonadas en el mapa en este momento.")
        end
        task.wait(600) -- 600 segundos = 10 minutos
    end
end)
