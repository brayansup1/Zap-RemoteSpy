-- 4. LOGICA DE INTERACCIÓN (Alternar Estado de Frutas)
local botonesFrutas = {}

for _, item in ipairs(FrutasConfig) do
	local nombre = item[1]
	
	local Fila = Instance.new("Frame")
	Fila.Size = UDim2.new(1, -5, 0, 30)
	Fila.BackgroundTransparency = 1
	Fila.Parent = ContenedorLista
	
	local NombreTexto = Instance.new("TextLabel")
	NombreTexto.Size = UDim2.new(0.6, 0, 1, 0)
	NombreTexto.BackgroundTransparency = 1
	NombreTexto.Text = "  " .. nombre
	NombreTexto.TextColor3 = Color3.fromRGB(200, 200, 200)
	NombreTexto.TextXAlignment = Enum.TextXAlignment.Left
	NombreTexto.Font = Enum.Font.SourceSans
	NombreTexto.TextSize = 16
	NombreTexto.Parent = Fila
	
	local BotonEstado = Instance.new("TextButton")
	BotonEstado.Size = UDim2.new(0.35, 0, 1, -4)
	BotonEstado.Position = UDim2.new(0.65, -5, 0, 2)
	BotonEstado.Font = Enum.Font.SourceSansBold
	BotonEstado.TextSize = 12
	BotonEstado.Parent = Fila
	
	local CornerB = Instance.new("UICorner")
	CornerB.CornerRadius = UDim.new(0, 6)
	CornerB.Parent = BotonEstado
	
	-- Función local para actualizar visualmente el botón (ON/OFF)
	local function actualizarBoton(activo: boolean)
		if activo then
			BotonEstado.Text = "BUSCAR"
			BotonEstado.BackgroundColor3 = Color3.fromRGB(52, 152, 219)
			BotonEstado.TextColor3 = Color3.fromRGB(255, 255, 255)
		else
			BotonEstado.Text = "IGNORAR"
			BotonEstado.BackgroundColor3 = Color3.fromRGB(60, 60, 65)
			BotonEstado.TextColor3 = Color3.fromRGB(130, 130, 130)
		end
	end
	
	actualizarBoton(item[2])
	
	BotonEstado.MouseButton1Click:Connect(function()
		item[2] = not item[2] -- Alterna el valor booleano en nuestra base de datos
		actualizarBoton(item[2])
	end)
end

-- 5. INTERRUPTOR DE APERTURA / CIERRE DEL PANEL
