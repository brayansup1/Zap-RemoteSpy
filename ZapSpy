-- Estado 1: Ir al NPC Rokya
local function irARokya()
	currentState = "GOING_TO_QUEST"
	print("🚶 Yendo hacia Rokya...")
	
	local rokya = encontrarNPC(FarmConfig.QuestNPC)
	if not rokya then
		print("❌ No se encontró a Rokya")
		return false
	end
	
	local rootPart = rokya:FindFirstChild("HumanoidRootPart")
	if not rootPart then return false end
	
	-- Moverse cerca de Rokya
	moverAPosicion(rootPart.Position + Vector3.new(0, 0, 5), 80)
	return true
end

-- Estado 2: Interactuar con Rokya (presionar E)
local function interactuarConRokya()
	currentState = "IN_DIALOG"
	print("💬 Interactuando con Rokya...")
	
	local rokya = encontrarNPC(FarmConfig.QuestNPC)
	if not rokya then return false end
	
	local prompt = encontrarPrompt(rokya)
	if not prompt then
		-- Intentar con tecla E directamente
		VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
		task.wait(0.1)
		VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
	else
		fireproximityprompt(prompt)
	end
	
	task.wait(1.5) -- Esperar que aparezca el diálogo
	
	return true
end

-- Estado 3: Seleccionar misión en el diálogo
local function seleccionarMision()
	print("🎯 Seleccionando misión:", FarmConfig.SelectedQuest)
	
	-- Buscar el botón de la misión en la GUI
	local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
	if not playerGui then return false end
	
	-- Esperar un poco por el diálogo
	task.wait(1)
	
	-- Buscar botones de diálogo (esto varía según el juego)
	for _, gui in ipairs(playerGui:GetDescendants()) do
		if gui:IsA("TextButton") or gui:IsA("ImageButton") then
			local texto = gui.Text:lower()
			if texto:find(FarmConfig.SelectedQuest:lower()) or 
			   (FarmConfig.SelectedQuest == "Hollows" and texto:find("hollow")) or
			   (FarmConfig.SelectedQuest == "Menos Grande" and texto:find("menos")) then
				
				print("✅ Botón encontrado:", gui.Text)
				
				-- Simular clic en el botón
				local posicion = gui.AbsolutePosition + gui.AbsoluteSize / 2
				VirtualInputManager:SendMouseButtonEvent(posicion.X, posicion.Y, 0, true, game, 1)
				task.wait(0.1)
				VirtualInputManager:SendMouseButtonEvent(posicion.X, posicion.Y, 0, false, game, 1)
				
				return true
			end
		end
	end
	
	-- Método alternativo: clic en coordenadas fijas (ajusta según tu pantalla)
	print("⚠️ Usando método alternativo de selección...")
	
	-- Clic en la posición donde debería estar el botón (ajusta estas coordenadas)
	-- Para "Hollows" generalmente es el segundo botón
	local x, y = 800, 450 -- Ajusta según tu resolución
	if FarmConfig.SelectedQuest == "Menos Grande" then
		x, y = 800, 500 -- Tercer botón
	end
	
	VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 1)
	task.wait(0.1)
	VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 1)
	
	return true
end

-- Estado 4: Farmear NPCs de la misión
local function farmearNPCsMision()
	currentState = "FARMING"
	print("⚔️ Farmeando", FarmConfig.SelectedQuest, "...")
	
	local npcsTargets = QuestNPCs[FarmConfig.SelectedQuest] or {"Hollow"}
	FarmConfig.NPCsToKill = 0
	
	while FarmConfig.QuestLoop and FarmConfig.NPCsToKill < FarmConfig.NPCsRequired do
		local encontrado = false
		
		for _, npcName in ipairs(npcsTargets) do
			for _, obj in ipairs(Workspace:GetDescendants()) do
				if obj:IsA("Model") and obj.Name:find(npcName) then
					local humanoid = obj:FindFirstChild("Humanoid")
					local rootNPC = obj:FindFirstChild("HumanoidRootPart")
					
					if humanoid and humanoid.Health > 0 and rootNPC then
						encontrado = true
						currentTarget = obj
						
						-- Moverse al NPC
						local character = LocalPlayer.Character
						local rootPart = character and character:FindFirstChild("HumanoidRootPart")
						if rootPart then
							-- Teletransporte suave hacia el NPC
							rootPart.CFrame = CFrame.new(rootNPC.Position + Vector3.new(0, 0, 8))
							rootPart.CFrame = CFrame.lookAt(rootPart.Position, rootNPC.Position)
							
							-- Atacar
							for i = 1, 20 do -- Ataque continuo
								if humanoid.Health <= 0 then break end
								
								-- Click para atacar
								VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
								task.wait(0.05)
								VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
								
								-- Skills
								if FarmConfig.AutoSkill then
									local tiempoActual = tick()
									if tiempoActual - lastSkillTime >= FarmConfig.SkillCooldown then
										lastSkillTime = tiempoActual
										for _, tecla in ipairs({"Z", "X", "C", "V"}) do
											VirtualInputManager:SendKeyEvent(true, Enum.KeyCode[tecla], false, game)
											task.wait(0.05)
											VirtualInputManager:SendKeyEvent(false, Enum.KeyCode[tecla], false, game)
										end
									end
								end
								
								task.wait(0.1)
							end
						end
					end
				end
			end
		end
		
		if not encontrado then
			-- Esperar a que aparezcan más NPCs
			task.wait(2)
		else
			FarmConfig.NPCsToKill = FarmConfig.NPCsToKill + 1
			print("☠️ NPCs matados:", FarmConfig.NPCsToKill, "/", FarmConfig.NPCsRequired)
		end
		
		task.wait(0.5)
	end
	
	return true
end

-- Estado 5: Regresar a Rokya
local function regresarARokya()
	currentState = "RETURNING"
	print("🔄 Regresando a Rokya...")
	
	task.wait(FarmConfig.ReturnDelay)
	
	-- Reiniciar el ciclo
	if FarmConfig.QuestLoop then
		task.spawn(function()
			cicloCompletoQuest()
		end)
	end
end

-- Ciclo completo
function cicloCompletoQuest()
	if not FarmConfig.QuestLoop then return end
	
	print("=== 🔄 INICIANDO CICLO DE QUEST ===")
	
	-- Paso 1: Ir a Rokya
	if not irARokya() then
		task.wait(3)
		cicloCompletoQuest()
		return
	end
	
	task.wait(1)
	
	-- Paso 2: Interactuar
	if not interactuarConRokya() then
		task.wait(3)
		cicloCompletoQuest()
		return
	end
	
	-- Paso 3: Seleccionar misión
	if not seleccionarMision() then
		task.wait(3)
		cicloCompletoQuest()
		return
	end
	
	task.wait(1)
	
	-- Paso 4: Farmear
	farmearNPCsMision()
	
	-- Paso 5: Regresar y repetir
	regresarARokya()
end

