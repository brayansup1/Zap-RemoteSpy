-- 6. BUCLE DE ESCANEO ULTRA CONSTANTE (Optimizado)
local autoScanActivo = false

BotonAuto.MouseButton1Click:Connect(function()
	autoScanActivo = not autoScanActivo
	if autoScanActivo then
		BotonAuto.Text = "🟢 SCAN CONSTANTE: ON"
		BotonAuto.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
	else
		BotonAuto.Text = "🔴 AUTO SCAN: OFF"
		BotonAuto.BackgroundColor3 = Color3.fromRGB(231, 76, 60)
	end
end)

task.spawn(function()
	while true do
		task.wait(1.5) -- Corrección fluida cada 1.5 segundos
		
		if autoScanActivo then
			local listaFiltroActiva = {}
			for _, item in ipairs(FrutasConfig) do
				if item[2] == true then table.insert(listaFiltroActiva, item[1]) end
			end
			
			for _, objeto in ipairs(Workspace:GetDescendants()) do
				if table.find(listaFiltroActiva, objeto.Name) and (objeto:IsA("Model") or objeto:IsA("BasePart")) then
					local character = LocalPlayer.Character
					local rootPart = character and character:FindFirstChild("HumanoidRootPart")
					if rootPart then
						print(`🎯 [Radar Constante] Fruta encontrada: {objeto.Name}`)
						rootPart.CFrame = objeto:GetPivot() * CFrame.new(0, 3, 0)
						break
					end
				end
			end
		end
	end
end)
