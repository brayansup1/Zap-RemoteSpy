local TS = game:GetService("TeleportService")
local W = game:GetService("Workspace")
local LP = game:GetService("Players").LocalPlayer

local fList = {"Budha", "Chop", "Flame", "Gear2", "Ice", "Light", "Magma", "Mochi", "Quake", "Rubber", "Sand", "String"}

print(`🕒 [{os.date("%X")}] Iniciando escaneo nativo seguro...`)
local encontrada = false

-- 1. Escaneo directo en el Workspace local
for _, o in ipairs(W:GetDescendants()) do
	if table.find(fList, o.Name) and (o:IsA("Model") or o:IsA("BasePart")) then
		local c = LP.Character
		local r = c and c:FindFirstChild("HumanoidRootPart")
		if r then
			print(`🎉 ¡FRUTA DETECTADA! -> {o.Name} a las {os.date("%X")}`)
			r.CFrame = o:GetPivot() * CFrame.new(0, 3, 0)
			encontrada = true
			break
		end
	end
end

-- 2. Si no hay fruta, hacemos el Server Hop sin usar HttpGet
if not encontrada then
	print("❌ No hay frutas aquí. Ejecutando salto de servidor nativo seguro...")
	
	-- Forzamos el teletransporte al mismo PlaceId. El motor de emparejamiento de Roblox
	-- se encargará de buscar de forma nativa otro servidor público disponible.
	local success, err = pcall(function()
		TS:Teleport(game.PlaceId, LP)
	end)
	
	if not success then
		warn("❌ Falló el teletransporte nativo: " .. tostring(err))
	end
end
