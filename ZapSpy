-- Guardar en tu carpeta 'autoexec'. Sistema de Ruptura de Caché por Desconexión Forzada.

local TeleportService = game:GetService("TeleportService")
local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")

if not game:IsLoaded() then
	game.Loaded:Wait()
end

local LocalPlayer = Players.LocalPlayer
while not LocalPlayer do
	task.wait(0.1)
	LocalPlayer = Players.LocalPlayer
end

-- 1. BASE DE DATOS LOCAL EN CARPETA TEMPORAL (Evita fallos de atributos)
local carpetaCache = game:GetService("CoreGui"):FindFirstChild("RadarCache")
if not carpetaCache then
	carpetaCache = Instance.new("Folder")
	carpetaCache.Name = "RadarCache"
	carpetaCache.Parent = game:GetService("CoreGui")
end

local valorUltimoServer = carpetaCache:FindFirstChild("LastJobId")
if not valorUltimoServer then
	valorUltimoServer = Instance.new("StringValue")
	valorUltimoServer.Name = "LastJobId"
	valorUltimoServer.Parent = carpetaCache
end

-- Si caímos exactamente en el mismo servidor de la última vez, ejecutamos desvío agresivo
if valorUltimoServer.Value == game.JobId then
	print("🚨 [Bucle Detectado] El motor de Roblox te devolvió a la misma sala. Rompiendo caché...")
	
	-- Truco: Romper la persistencia del personaje antes de saltar
	local character = LocalPlayer.Character
	if character then
		character:ClearAllChildren() -- Borra el cuerpo para forzar al juego a sacarte del bucle de red
	end
	
	task.wait(0.5)
	TeleportService:Teleport(game.PlaceId, LocalPlayer)
	return
else
	-- Guardamos el servidor actual para el próximo frame
	valorUltimoServer.Value = game.JobId
end

local fList = {"Budha", "Chop", "Flame", "Gear2", "Ice", "Light", "Magma", "Mochi", "Quake", "Rubber", "Sand", "String"}

print(`🕒 [{os.date("%X")}] [Radar Forzado] Conectado a Servidor Nuevo: {game.JobId}`)
task.wait(1.5)

local frutaObjetivo = nil

-- 2. ESCANEO DE SPONS LOCALES DE ZAP
for _, o in ipairs(Workspace:GetDescendants()) do
	if table.find(fList, o.Name) and (o:IsA("Model") or o:IsA("BasePart")) then
		frutaObjetivo = o
		break
	end
end

-- 3. CONTROL DE RECOLECCIÓN Y SALTO
if frutaObjetivo then
	local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
	local rootPart = character:WaitForChild("HumanoidRootPart", 5)
	
	if rootPart then
		print(`🎉 ¡FRUTA LOCALIZADA! -> {frutaObjetivo.Name} a las {os.date("%X")}`)
		rootPart.CFrame = frutaObjetivo:GetPivot() * CFrame.new(0, 3, 0)
		
		-- Esperar a que la limpies del mapa
		while frutaObjetivo and frutaObjetivo:IsDescendantOf(Workspace) do
			task.wait(1)
		end
		
		print("🧹 Mapa limpio de nuevo. Buscando nueva sala...")
		task.wait(1)
		TeleportService:Teleport(game.PlaceId, LocalPlayer)
	end
else
	print("❌ No hay frutas aquí. Forzando rotación de servidor...")
	task.wait(0.5)
	TeleportService:Teleport(game.PlaceId, LocalPlayer)
end
