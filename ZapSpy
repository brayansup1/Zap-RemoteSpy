-- Guardar en tu carpeta 'autoexec'. Flujo infinito e inteligente.

local TeleportService = game:GetService("TeleportService")
local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")

if not game:IsLoaded() then
	game.Loaded:Wait()
end

local LocalPlayer = Players.LocalPlayer
while not LocalPlayer do
	task.wait(0.1)
	LocalPlayer = Players.LocalPlayer
end

local fList = {"Budha", "Chop", "Flame", "Gear2", "Ice", "Light", "Magma", "Mochi", "Quake", "Rubber", "Sand", "String"}

-- Función segura para cambiar de servidor
local function iniciarServerHop()
	print("❌ Ejecutando salto forzado a una nueva instancia de servidor...")
	local opciones = Instance.new("TeleportOptions")
	opciones.ServerInstanceId = "" 
	
	local success, err = pcall(function()
		TeleportService:TeleportAsync(game.PlaceId, {LocalPlayer}, opciones)
	end)
	
	if not success then
		warn("❌ Error en TeleportAsync: " .. tostring(err))
		task.wait(2)
		TeleportService:Teleport(game.PlaceId, LocalPlayer)
	end
end

print(`🕒 [{os.date("%X")}] [Radar Continuo] Escaneando servidor...`)
task.wait(1.5)

local frutaObjetivo = nil

-- 1. BUSQUEDA INICIAL
for _, o in ipairs(Workspace:GetDescendants()) do
	if table.find(fList, o.Name) and (o:IsA("Model") or o:IsA("BasePart")) then
		frutaObjetivo = o
		break
	end
end

-- 2. EVALUACIÓN DE ACCIONES
if frutaObjetivo then
	local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
	local rootPart = character:WaitForChild("HumanoidRootPart", 5)
	
	if rootPart then
		print(`🎉 ¡FRUTA DETECTADA! -> {frutaObjetivo.Name} encontrada a las {os.date("%X")}`)
		rootPart.CFrame = frutaObjetivo:GetPivot() * CFrame.new(0, 3, 0)
		
		print("⏳ Esperando a que recolectes la fruta para continuar el viaje...")
		
		-- Bucle de espera: Se queda congelado aquí MIENTRAS la fruta exista en el juego
		while frutaObjetivo and frutaObjetivo:IsDescendantOf(Workspace) do
			task.wait(1) -- Revisa cada segundo si la fruta sigue ahí
		end
		
		print("🧹 La fruta ha desaparecido (recolectada). Reactivando Radar...")
		task.wait(1)
		iniciarServerHop()
	end
else
	print("❌ Este servidor no tiene frutas activas.")
	iniciarServerHop()
end
