	Panel.Visible = not Panel.Visible
	BotonMenu.Text = Panel.Visible and "❌" or "🍎"
end)

-- 6. MOTOR DE ESCANEO Y TELETRANSPORTE FILTRADO
BotonEscaneo.MouseButton1Click:Connect(function()
	BotonEscaneo.Text = "ESCANEANDO..."
	BotonEscaneo.BackgroundColor3 = Color3.fromRGB(230, 126, 34)
	task.wait(0.3)
	
	-- Crear una lista limpia de lo que el usuario quiere buscar actualmente
	local listaFiltroActiva = {}
	for _, item in ipairs(FrutasConfig) do
		if item[2] == true then
			table.insert(listaFiltroActiva, item[1])
		end
	end
	
	local encontrada = false
	
	-- Barrido por el Workspace del juego
	for _, objeto in ipairs(Workspace:GetDescendants()) do
		if table.find(listaFiltroActiva, objeto.Name) and (objeto:IsA("Model") or objeto:IsA("BasePart")) then
			local character = LocalPlayer.Character
			local rootPart = character and character:FindFirstChild("HumanoidRootPart")
			
			if rootPart then
				print(`🎯 [Radar] ¡Fruta seleccionada localizada!: {objeto.Name} a las {os.date("%X")}`)
				rootPart.CFrame = objeto:GetPivot() * CFrame.new(0, 3, 0)
				encontrada = true
				break
			end
		end
	end
	
	-- Retroalimentación visual en el botón tras el escaneo
	if encontrada then
		BotonEscaneo.Text = "✅ ¡FRUTA ENCONTRADA!"
		BotonEscaneo.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
	else
		BotonEscaneo.Text = "❌ SIN FRUTAS ACTIVAS"
		BotonEscaneo.BackgroundColor3 = Color3.fromRGB(231, 76, 60)
	end
	
	task.wait(1.5)
	BotonEscaneo.Text = "🔍 ESCANEAR MAPA"
	BotonEscaneo.BackgroundColor3 = Color3.fromRGB(46, 204, 113)
end)

print("✅ Interfaz de Radar Móvil cargada con éxito. Presiona el botón de la manzana 🍎.")
